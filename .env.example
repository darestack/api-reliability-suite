# Project Settings
# ----------------
PROJECT_NAME="API Reliability Suite"
ENVIRONMENT="development"
DEBUG=false
LOG_LEVEL="info"
LOG_FILE_PATH="app.json"

# Security (CHANGE THESE IN PROD!)
# ------------------------------
SECRET_KEY="change-me-to-a-secure-random-string"
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Rate Limiting
# -------------
RATE_LIMIT_STORAGE_URI="memory://"
RATE_LIMIT_HEADERS_ENABLED=false
RATE_LIMIT_KEY_PREFIX="api-reliability-suite"
# SETTINGS_SECRETS_DIR="/run/secrets"

# Observability
# -------------
# OTLP_ENDPOINT="http://localhost:4317"  # Uncomment to send traces to Jaeger/Tempo
# PROMETHEUS_BASE_URL="http://localhost:9099"

# Data Layer
# ----------
DATABASE_URL="sqlite+aiosqlite:///./data/reliability_suite.db"
# DATABASE_URL="postgresql+asyncpg://app:app@localhost:5432/reliability_suite"
SEED_DEMO_USER=true
DEMO_USERNAME="demo"
DEMO_PASSWORD="secret123"
DEMO_USER_ROLE="admin"

# Reliability Features
# --------------------
# CIRCUIT_BREAKER_CACHE_URL="redis://localhost:6379/1"
CIRCUIT_BREAKER_CACHE_TTL_SECONDS=300
SLO_TARGET_SUCCESS_RATIO=0.99
SLO_TARGET_P99_LATENCY_SECONDS=1.0

# AI / LLM Keys (Set ONE of these to enable AI Log Analysis)
# --------------------------------------------------------
# GROQ_API_KEY="gsk_..."
# OPENAI_API_KEY="sk-..."
# GOOGLE_API_KEY="AIza..."
